{
  "name": "beacon-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:acceptance": "bun test test/acceptance/",
    "test:e2e": "playwright test",
    "migrate": "bun run packages/beacon/src/storage/migrate.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "format": "biome check --write",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@pi-innovations/beacon": "workspace:*",
    "@pi-innovations/beacon-client": "workspace:*",
    "@playwright/test": "1.60.0",
    "@types/bun": "latest",
    "hono": "^4.12.21",
    "lefthook": "2.1.8",
    "typescript": "^5.7.0"
  }
}
